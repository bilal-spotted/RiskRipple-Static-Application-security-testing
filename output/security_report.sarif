            {
              "id": "TAINT-CMD",
              "name": "TAINT-CMD",
              "shortDescription": {
                "text": "Taint flow to command execution"
              },
              "fullDescription": {
                "text": "Tainted user input flows into shell/process execution; may allow command injection.\nRemediation: Use allowlists and avoid shell=True; prefer subprocess with list args.\nReferences: CWE-78, A03:2021-Injection"
