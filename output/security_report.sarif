              "id": "SEC007",
              "name": "SEC007",
              "shortDescription": {
                "text": "Potential hardcoded bearer token"
              },
              "fullDescription": {
                "text": "Possible hardcoded bearer token detected.\nRemediation: Remove tokens from source code and load them securely.\nReferences: CWE-798"
