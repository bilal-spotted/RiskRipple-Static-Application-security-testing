              "id": "SEC009",
              "name": "SEC009",
              "shortDescription": {
                "text": "Insecure random for security-sensitive context"
              },
              "fullDescription": {
                "text": "The random module is not cryptographically secure for tokens or secrets.\nRemediation: Use the secrets module for tokens/keys, or os.urandom for raw bytes.\nReferences: CWE-330"
              },
              "help": {
                "text": "Use the secrets module for tokens/keys, or os.urandom for raw bytes. (CWE-330)"
