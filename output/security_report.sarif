                "owasp": "A02:2021-Cryptographic Failures"
              }
            },
            {
              "id": "SEC006",
              "name": "SEC006",
              "shortDescription": {
                "text": "Insecure SHA-1 usage"
              },
              "fullDescription": {
                "text": "SHA-1 is deprecated for many security-sensitive use cases.\nRemediation: Use SHA-256 or stronger modern cryptographic primitives.\nReferences: CWE-328, A02:2021-Cryptographic Failures"
              },
              "help": {
                "text": "Use SHA-256 or stronger modern cryptographic primitives. (CWE-328) [A02:2021-Cryptographic Failures]"
              },
              "properties": {
                "category": "Cryptography",
                "severity": "MEDIUM",
                "confidence": "MEDIUM",
