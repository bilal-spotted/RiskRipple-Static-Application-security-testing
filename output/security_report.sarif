{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Risk Ripple",
          "informationUri": "https://example.com",
          "version": "1.0.0",
          "rules": [
            {
              "id": "GEN001",
              "name": "GEN001",
              "shortDescription": {
                "text": "Possible eval usage"
              },
              "fullDescription": {
                "text": "eval() may execute untrusted input (detected by pattern).\nRemediation: Avoid eval(). Use safe parsing or explicit logic.\nReferences: CWE-94"
              },
              "help": {
                "text": "Avoid eval(). Use safe parsing or explicit logic. (CWE-94)"
              },
              "properties": {
                "category": "Code Injection",
                "severity": "HIGH",
                "confidence": "LOW",
                "cwe": "CWE-94"
              }
            },
            {
              "id": "GEN002",
              "name": "GEN002",
              "shortDescription": {
                "text": "Possible exec usage"
              },
              "fullDescription": {
                "text": "exec() may execute untrusted input (detected by pattern).\nRemediation: Avoid exec(). Use safer explicit logic.\nReferences: CWE-95"
              },
              "help": {
                "text": "Avoid exec(). Use safer explicit logic. (CWE-95)"
              },
              "properties": {
                "category": "Code Injection",
                "severity": "HIGH",
                "confidence": "LOW",
                "cwe": "CWE-95"
              }
            },
            {
              "id": "PY001",
              "name": "PY001",
              "shortDescription": {
                "text": "Use of eval()"
              },
              "fullDescription": {
                "text": "eval() executes dynamic Python code and may allow code injection when given untrusted input.\nRemediation: Avoid eval(). Use safe parsing, explicit logic, or restricted parsing libraries.\nReferences: CWE-94, A03:2021-Injection"
              },
              "help": {
                "text": "Avoid eval(). Use safe parsing, explicit logic, or restricted parsing libraries. (CWE-94) [A03:2021-Injection]"
              },
              "properties": {
                "category": "Code Injection",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-94",
                "owasp": "A03:2021-Injection"
              }
            },
            {
              "id": "PY002",
              "name": "PY002",
              "shortDescription": {
                "text": "Use of exec()"
              },
              "fullDescription": {
                "text": "exec() executes dynamic Python code and can introduce severe security risk.\nRemediation: Avoid exec(). Replace with explicit logic or safer alternatives.\nReferences: CWE-95, A03:2021-Injection"
              },
              "help": {
                "text": "Avoid exec(). Replace with explicit logic or safer alternatives. (CWE-95) [A03:2021-Injection]"
              },
              "properties": {
                "category": "Code Injection",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-95",
                "owasp": "A03:2021-Injection"
              }
            },
            {
              "id": "PY003",
              "name": "PY003",
              "shortDescription": {
                "text": "Use of os.system()"
              },
              "fullDescription": {
                "text": "os.system() may lead to command injection if arguments include untrusted input.\nRemediation: Use subprocess.run() with a list of arguments and avoid shell interpretation.\nReferences: CWE-78, A03:2021-Injection"
              },
              "help": {
                "text": "Use subprocess.run() with a list of arguments and avoid shell interpretation. (CWE-78) [A03:2021-Injection]"
              },
              "properties": {
                "category": "Command Injection",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-78",
                "owasp": "A03:2021-Injection"
              }
            },
            {
              "id": "PY004",
              "name": "PY004",
              "shortDescription": {
                "text": "Subprocess with shell=True"
              },
              "fullDescription": {
                "text": "shell=True increases command injection risk when command content is not fully trusted.\nRemediation: Avoid shell=True. Pass command arguments as a list instead.\nReferences: CWE-78, A03:2021-Injection"
              },
              "help": {
                "text": "Avoid shell=True. Pass command arguments as a list instead. (CWE-78) [A03:2021-Injection]"
              },
              "properties": {
                "category": "Command Injection",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-78",
                "owasp": "A03:2021-Injection"
              }
            },
            {
              "id": "PY005",
              "name": "PY005",
              "shortDescription": {
                "text": "Unsafe pickle deserialization"
              },
              "fullDescription": {
                "text": "pickle deserialization may execute arbitrary code when loading untrusted data.\nRemediation: Do not deserialize untrusted pickle data. Use JSON or other safe formats.\nReferences: CWE-502, A08:2021-Software and Data Integrity Failures"
              },
              "help": {
                "text": "Do not deserialize untrusted pickle data. Use JSON or other safe formats. (CWE-502) [A08:2021-Software and Data Integrity Failures]"
              },
              "properties": {
                "category": "Unsafe Deserialization",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-502",
                "owasp": "A08:2021-Software and Data Integrity Failures"
              }
            },
            {
              "id": "PY006",
              "name": "PY006",
              "shortDescription": {
                "text": "Use of yaml.load()"
              },
              "fullDescription": {
                "text": "yaml.load() may be unsafe when parsing untrusted YAML content.\nRemediation: Prefer yaml.safe_load() for untrusted input.\nReferences: CWE-502, A08:2021-Software and Data Integrity Failures"
              },
              "help": {
                "text": "Prefer yaml.safe_load() for untrusted input. (CWE-502) [A08:2021-Software and Data Integrity Failures]"
              },
              "properties": {
                "category": "Unsafe Deserialization",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-502",
                "owasp": "A08:2021-Software and Data Integrity Failures"
              }
            },
            {
              "id": "PY007",
              "name": "PY007",
              "shortDescription": {
                "text": "Use of compile()"
              },
              "fullDescription": {
                "text": "compile() builds code objects from strings; with untrusted input it can enable code execution (e.g. via exec()).\nRemediation: Avoid compiling untrusted input. Use safe parsing or restricted modes; prefer structured data over code strings.\nReferences: CWE-94, A03:2021-Injection"
              },
              "help": {
                "text": "Avoid compiling untrusted input. Use safe parsing or restricted modes; prefer structured data over code strings. (CWE-94) [A03:2021-Injection]"
              },
              "properties": {
                "category": "Code Injection",
                "severity": "HIGH",
                "confidence": "MEDIUM",
                "cwe": "CWE-94",
                "owasp": "A03:2021-Injection"
              }
            },
            {
              "id": "RH001",
              "name": "RH001",
              "shortDescription": {
                "text": "Tracked cache or build directory"
              },
              "fullDescription": {
                "text": "Directory such as __pycache__ should not be committed; it is generated/cache content.\nRemediation: Add to .gitignore and remove from index if already tracked (git rm -r --cached)."
              },
              "help": {
                "text": "Add to .gitignore and remove from index if already tracked (git rm -r --cached)."
              },
              "properties": {
                "category": "Repository Hygiene",
                "severity": "MEDIUM",
                "confidence": "HIGH"
              }
            },
            {
              "id": "RH002",
              "name": "RH002",
              "shortDescription": {
                "text": "Environment or secret file tracked"
              },
              "fullDescription": {
                "text": "Environment or secret-bearing file (e.g. .env) should not be committed.\nRemediation: Add .env to .gitignore; revoke/rotate any exposed secrets; git rm --cached.\nReferences: CWE-798"
              },
              "help": {
                "text": "Add .env to .gitignore; revoke/rotate any exposed secrets; git rm --cached. (CWE-798)"
              },
              "properties": {
                "category": "Sensitive Artifacts",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-798"
              }
            },
            {
              "id": "RH003",
              "name": "RH003",
              "shortDescription": {
                "text": "Private key or certificate artifact"
              },
              "fullDescription": {
                "text": "Private key or certificate file should never be committed.\nRemediation: Revoke/rotate the key; remove from repo; add *.pem, *.key, id_rsa to .gitignore.\nReferences: CWE-321"
              },
              "help": {
                "text": "Revoke/rotate the key; remove from repo; add *.pem, *.key, id_rsa to .gitignore. (CWE-321)"
              },
              "properties": {
                "category": "Secret Exposure",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-321"
              }
            },
            {
              "id": "RH004",
              "name": "RH004",
              "shortDescription": {
                "text": "Python bytecode file tracked"
              },
              "fullDescription": {
                "text": "Compiled .pyc file should not be committed.\nRemediation: Add *.pyc and __pycache__/ to .gitignore; git rm --cached '*.pyc'."
              },
              "help": {
                "text": "Add *.pyc and __pycache__/ to .gitignore; git rm --cached '*.pyc'."
              },
              "properties": {
                "category": "Repository Hygiene",
                "severity": "LOW",
                "confidence": "HIGH"
              }
            },
            {
              "id": "RH004b",
              "name": "RH004b",
              "shortDescription": {
                "text": "Python optimized bytecode file tracked"
              },
              "fullDescription": {
                "text": "Compiled .pyo file should not be committed.\nRemediation: Add *.pyo to .gitignore; git rm --cached '*.pyo'."
              },
              "help": {
                "text": "Add *.pyo to .gitignore; git rm --cached '*.pyo'."
              },
              "properties": {
                "category": "Repository Hygiene",
                "severity": "LOW",
                "confidence": "HIGH"
              }
            },
            {
              "id": "RH005",
              "name": "RH005",
              "shortDescription": {
                "text": "Secret or API key detected in file"
              },
              "fullDescription": {
                "text": "File content matches secret/API key pattern; treat as exposed.\nRemediation: Revoke/rotate the key; remove from git; consider purging from history.\nReferences: CWE-798"
              },
              "help": {
                "text": "Revoke/rotate the key; remove from git; consider purging from history. (CWE-798)"
              },
              "properties": {
                "category": "Secret Exposure",
                "severity": "CRITICAL",
                "confidence": "HIGH",
                "cwe": "CWE-798"
              }
            },
            {
              "id": "RH010",
              "name": "RH010",
              "shortDescription": {
                "text": ".gitignore missing critical patterns"
              },
              "fullDescription": {
                "text": ".gitignore does not include recommended patterns; rules do not remove already tracked files.\nRemediation: Add .env, __pycache__/, *.pyc, *.pyo, venv/ to .gitignore; git rm --cached for tracked sensitive files."
              },
              "help": {
                "text": "Add .env, __pycache__/, *.pyc, *.pyo, venv/ to .gitignore; git rm --cached for tracked sensitive files."
              },
              "properties": {
                "category": "Repository Hygiene",
                "severity": "HIGH",
                "confidence": "HIGH"
              }
            },
            {
              "id": "RH011",
              "name": "RH011",
              "shortDescription": {
                "text": "Verify sensitive files are not tracked"
              },
              "fullDescription": {
                "text": ".gitignore rules do not remove files already tracked by git.\nRemediation: Run git ls-files and use git rm --cached for any .env, __pycache__, *.pyc, venv."
              },
              "help": {
                "text": "Run git ls-files and use git rm --cached for any .env, __pycache__, *.pyc, venv."
              },
              "properties": {
                "category": "Repository Hygiene",
                "severity": "MEDIUM",
                "confidence": "HIGH"
              }
            },
            {
              "id": "SEC001",
              "name": "SEC001",
              "shortDescription": {
                "text": "Potential hardcoded password"
              },
              "fullDescription": {
                "text": "Possible hardcoded password detected in source.\nRemediation: Move secrets to environment variables or a secure secrets manager.\nReferences: CWE-798, A07:2021-Identification and Authentication Failures"
              },
              "help": {
                "text": "Move secrets to environment variables or a secure secrets manager. (CWE-798) [A07:2021-Identification and Authentication Failures]"
              },
              "properties": {
                "category": "Secrets",
                "severity": "HIGH",
                "confidence": "MEDIUM",
                "cwe": "CWE-798",
                "owasp": "A07:2021-Identification and Authentication Failures"
              }
            },
            {
              "id": "SEC002",
              "name": "SEC002",
              "shortDescription": {
                "text": "Potential hardcoded API key or token"
              },
              "fullDescription": {
                "text": "Possible hardcoded credential or token detected.\nRemediation: Store credentials outside source code and inject them securely at runtime.\nReferences: CWE-798, A07:2021-Identification and Authentication Failures"
              },
              "help": {
                "text": "Store credentials outside source code and inject them securely at runtime. (CWE-798) [A07:2021-Identification and Authentication Failures]"
              },
              "properties": {
                "category": "Secrets",
                "severity": "HIGH",
                "confidence": "MEDIUM",
                "cwe": "CWE-798",
                "owasp": "A07:2021-Identification and Authentication Failures"
              }
            },
            {
              "id": "SEC003",
              "name": "SEC003",
              "shortDescription": {
                "text": "Flask debug mode enabled"
              },
              "fullDescription": {
                "text": "Debug mode may expose sensitive information in production.\nRemediation: Disable debug mode in production deployments.\nReferences: CWE-489, A05:2021-Security Misconfiguration"
              },
              "help": {
                "text": "Disable debug mode in production deployments. (CWE-489) [A05:2021-Security Misconfiguration]"
              },
              "properties": {
                "category": "Insecure Configuration",
                "severity": "MEDIUM",
                "confidence": "HIGH",
                "cwe": "CWE-489",
                "owasp": "A05:2021-Security Misconfiguration"
              }
            },
            {
              "id": "SEC004",
              "name": "SEC004",
              "shortDescription": {
                "text": "TLS certificate verification disabled"
              },
              "fullDescription": {
                "text": "Disabling certificate verification weakens transport security.\nRemediation: Enable certificate verification and trust valid CA certificates.\nReferences: CWE-295, A07:2021-Identification and Authentication Failures"
              },
              "help": {
                "text": "Enable certificate verification and trust valid CA certificates. (CWE-295) [A07:2021-Identification and Authentication Failures]"
              },
              "properties": {
                "category": "TLS/SSL",
                "severity": "HIGH",
                "confidence": "HIGH",
                "cwe": "CWE-295",
                "owasp": "A07:2021-Identification and Authentication Failures"
              }
            },
            {
              "id": "SEC005",
              "name": "SEC005",
              "shortDescription": {
                "text": "Insecure MD5 usage"
              },
              "fullDescription": {
                "text": "MD5 is not suitable for security-sensitive cryptographic use.\nRemediation: Use SHA-256 or stronger; use password hashing libraries for passwords.\nReferences: CWE-328, A02:2021-Cryptographic Failures"
              },
              "help": {
                "text": "Use SHA-256 or stronger; use password hashing libraries for passwords. (CWE-328) [A02:2021-Cryptographic Failures]"
              },
              "properties": {
                "category": "Cryptography",
                "severity": "MEDIUM",
                "confidence": "MEDIUM",
